PORT=4000
NODE_ENV=development
DATABASE_PATH=./data/elama.db
ACCESS_TOKEN_SECRET=change-me-access-secret-min-32-chars-long
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
COOKIE_DOMAIN=

# --- AI providers ---
# Groq — Llama 3.3 70B for caption / strategy / orchestrator
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Google Gemini — "Nano Banana" image generator
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Image generator: "pollinations" (free, zero auth) or "nano-banana" (Gemini, requires billing)
IMAGE_PROVIDER=pollinations

# Image storage
STORAGE_PATH=./data/generated
